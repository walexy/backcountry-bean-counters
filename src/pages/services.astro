---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services" description="Monthly bookkeeping packages and one-time services for Vermont small businesses.">
  <!-- Hero -->
  <section class="relative py-24 md:py-32 bg-forest overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-dark via-forest to-evergreen"></div>
    <div class="absolute inset-0 topo-pattern opacity-20"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="animate-fade-up inline-block text-gold font-medium tracking-wider uppercase text-sm mb-6">Our Services</span>
      <h1 class="animate-fade-up delay-100 font-display text-5xl md:text-6xl text-white mb-6">
        Bookkeeping That<br/>
        <span class="text-gold">Works for You</span>
      </h1>
      <p class="animate-fade-up delay-200 text-xl text-white/80 max-w-2xl mx-auto">
        Simple, reliable bookkeeping tailored to your needs. Choose a monthly package or pick the services you need.
      </p>
    </div>
  </section>

  <!-- Monthly Packages -->
  <section class="py-24 md:py-32 bg-cream relative paper-texture">
    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 text-forest-light mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
          </svg>
          <span class="font-medium tracking-wider uppercase text-sm">Monthly Plans</span>
        </div>
        <h2 class="font-display text-4xl md:text-5xl text-forest mb-6">
          Monthly Bookkeeping Packages
        </h2>
        <p class="text-slate text-lg max-w-2xl mx-auto">
          Choose a plan that grows with your business. All packages include personalized attention and Vermont-based service.
        </p>
      </div>

      <!-- Pricing cards -->
      <div class="grid lg:grid-cols-3 gap-6 lg:gap-8 mb-12">
        <!-- Trailhead -->
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 overflow-hidden card-lift">
          <!-- Header -->
          <div class="bg-gradient-to-br from-forest-light/10 to-forest/5 p-8 text-center border-b border-forest/5">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-forest-light/10 text-forest-light mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/>
              </svg>
            </div>
            <h3 class="font-display text-3xl text-forest mb-2">Trailhead</h3>
            <span class="inline-block px-3 py-1 bg-forest-light/10 text-forest-light rounded-full text-sm font-medium">Basic</span>
          </div>

          <!-- Content -->
          <div class="p-8">
            <p class="text-slate text-center mb-8 font-medium">For small, simple businesses</p>

            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-forest-light/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-forest-light" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Bank & credit card reconciliation</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-forest-light/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-forest-light" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Expense categorization</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-forest-light/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-forest-light" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Monthly financial reports</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-forest-light/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-forest-light" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Email support 1x per week</span>
              </li>
            </ul>

            <a href="/contact" class="block w-full text-center py-3.5 px-6 rounded-lg border-2 border-forest text-forest font-semibold hover:bg-forest hover:text-white transition-all duration-300">
              Get Started
            </a>
          </div>
        </div>

        <!-- Ridgeline (Featured) -->
        <div class="group bg-forest rounded-2xl shadow-2xl relative lg:-translate-y-6 overflow-hidden">
          <!-- Popular badge -->
          <div class="absolute top-0 left-0 right-0 bg-gold text-forest-dark text-center text-sm font-bold py-2">
            Most Popular
          </div>

          <!-- Background decoration -->
          <div class="absolute inset-0 topo-pattern opacity-10"></div>

          <!-- Header -->
          <div class="relative z-10 pt-14 pb-8 px-8 text-center border-b border-white/10">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-gold/20 text-gold mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
              </svg>
            </div>
            <h3 class="font-display text-3xl text-white mb-2">Ridgeline</h3>
            <span class="inline-block px-3 py-1 bg-white/10 text-gold rounded-full text-sm font-medium">Standard</span>
          </div>

          <!-- Content -->
          <div class="relative z-10 p-8">
            <p class="text-white/80 text-center mb-8 font-medium">For growing businesses</p>

            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-white/90"><strong class="text-white">Everything in Trailhead</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-white/90">Unlimited email support</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-white/90">Accounts payable (bill tracking)</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-white/90">Accounts receivable (invoice tracking)</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-gold/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-gold" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-white/90">Monthly summary + insights</span>
              </li>
            </ul>

            <a href="/contact" class="btn-primary block w-full text-center">
              <span>Get Started</span>
            </a>
          </div>
        </div>

        <!-- Summit -->
        <div class="group bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-500 overflow-hidden card-lift">
          <!-- Header -->
          <div class="bg-gradient-to-br from-bark/10 to-bark/5 p-8 text-center border-b border-bark/5">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl bg-bark/10 text-bark mb-4">
              <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <h3 class="font-display text-3xl text-forest mb-2">Summit</h3>
            <span class="inline-block px-3 py-1 bg-bark/10 text-bark rounded-full text-sm font-medium">Premium</span>
          </div>

          <!-- Content -->
          <div class="p-8">
            <p class="text-slate text-center mb-8 font-medium">For established businesses</p>

            <ul class="space-y-4 mb-8">
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-bark/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-bark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate"><strong class="text-forest">Everything in Ridgeline</strong></span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-bark/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-bark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Cash flow tracking</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-bark/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-bark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Budgeting support</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-bark/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-bark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Payroll coordination or processing</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-bark/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-bark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Priority support</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-bark/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-bark" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <span class="text-slate">Tax prep</span>
              </li>
            </ul>

            <a href="/contact" class="block w-full text-center py-3.5 px-6 rounded-lg border-2 border-forest text-forest font-semibold hover:bg-forest hover:text-white transition-all duration-300">
              Get Started
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- One-Time Services -->
  <section class="py-24 md:py-32 bg-parchment">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <!-- Section header -->
      <div class="text-center mb-16">
        <div class="inline-flex items-center gap-2 text-bark mb-4">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>
          </svg>
          <span class="font-medium tracking-wider uppercase text-sm">À La Carte</span>
        </div>
        <h2 class="font-display text-4xl md:text-5xl text-forest mb-6">
          One-Time & À La Carte Services
        </h2>
        <p class="text-slate text-lg max-w-2xl mx-auto">
          Need help with a specific project? These services are available as standalone offerings.
        </p>
      </div>

      <!-- Services grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Service cards -->
        <div class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-forest/5 card-lift">
          <div class="w-12 h-12 rounded-lg bg-forest-light/10 flex items-center justify-center text-forest-light mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-forest mb-3">Book Cleanup / Catch-Up</h3>
          <p class="text-slate leading-relaxed">Get your books back on track with a thorough review and cleanup of past records.</p>
        </div>

        <div class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-forest/5 card-lift">
          <div class="w-12 h-12 rounded-lg bg-forest-light/10 flex items-center justify-center text-forest-light mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-forest mb-3">QuickBooks Setup</h3>
          <p class="text-slate leading-relaxed">Professional setup of your QuickBooks account, customized for your business needs.</p>
        </div>

        <div class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-forest/5 card-lift">
          <div class="w-12 h-12 rounded-lg bg-forest-light/10 flex items-center justify-center text-forest-light mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-forest mb-3">Reconciliation Only</h3>
          <p class="text-slate leading-relaxed">Monthly or quarterly bank and credit card reconciliation services.</p>
        </div>

        <div class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-forest/5 card-lift">
          <div class="w-12 h-12 rounded-lg bg-forest-light/10 flex items-center justify-center text-forest-light mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-forest mb-3">Accounts Payable / Receivable</h3>
          <p class="text-slate leading-relaxed">Standalone bill tracking and invoice management services.</p>
        </div>

        <div class="group bg-white rounded-xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border border-forest/5 card-lift">
          <div class="w-12 h-12 rounded-lg bg-forest-light/10 flex items-center justify-center text-forest-light mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-forest mb-3">Consulting / Training</h3>
          <p class="text-slate leading-relaxed">One-on-one guidance to help you understand your financials and improve your processes.</p>
        </div>

        <!-- Free consultation highlight -->
        <div class="group bg-gradient-to-br from-gold/10 to-gold/5 rounded-xl p-8 shadow-sm hover:shadow-lg transition-all duration-300 border-2 border-gold/30 card-lift">
          <div class="w-12 h-12 rounded-lg bg-gold/20 flex items-center justify-center text-gold mb-5 group-hover:scale-110 transition-transform duration-300">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
          </div>
          <h3 class="font-display text-xl text-forest mb-3">Free Consultation</h3>
          <p class="text-slate leading-relaxed">A free 30-minute consultation to review your books and recommend the best plan for your business.</p>
