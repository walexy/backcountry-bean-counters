---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with BackCountry Bean Counter. Book a free 30-minute consultation.">
  <!-- Hero -->
  <section class="relative py-24 md:py-32 bg-forest overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-forest-dark via-forest to-evergreen"></div>
    <div class="absolute inset-0 topo-pattern opacity-20"></div>

    <div class="relative z-10 max-w-4xl mx-auto px-6 lg:px-8 text-center">
      <span class="animate-fade-up inline-block text-gold font-medium tracking-wider uppercase text-sm mb-6">Get in Touch</span>
      <h1 class="animate-fade-up delay-100 font-display text-5xl md:text-6xl text-white mb-6">
        Let's Talk About<br/>
        <span class="text-gold">Your Books</span>
      </h1>
      <p class="animate-fade-up delay-200 text-xl text-white/80 max-w-2xl mx-auto">
        Ready to get your finances in order? I'd love to hear about your business and how I can help.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-24 md:py-32 bg-cream relative paper-texture">
    <div class="relative z-10 max-w-6xl mx-auto px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <!-- Contact Info -->
        <div class="lg:col-span-2">
          <h2 class="font-display text-3xl text-forest mb-6">Get In Touch</h2>
          <p class="text-slate text-lg leading-relaxed mb-10">
            I offer a free 30-minute consultation to review your books and recommend the best plan for your business. No pressure, just a conversation.
          </p>

          <!-- Contact cards -->
          <div class="space-y-6 mb-10">
            <div class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border border-forest/5">
              <div class="w-12 h-12 rounded-lg bg-forest flex items-center justify-center text-white flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg text-forest mb-1">Location</h3>
                <p class="text-slate">Serving Central Vermont</p>
                <p class="text-slate/70 text-sm mt-1">Remote services available statewide</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border border-forest/5">
              <div class="w-12 h-12 rounded-lg bg-forest flex items-center justify-center text-white flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg text-forest mb-1">Email</h3>
                <a href="mailto:hello@backcountrybeancounter.com" class="text-forest hover:text-gold transition-colors font-medium">
                  hello@backcountrybeancounter.com
                </a>
                <p class="text-slate/70 text-sm mt-1">I typically respond within 24 hours</p>
              </div>
            </div>

            <div class="flex items-start gap-4 p-5 bg-white rounded-xl shadow-sm border border-forest/5">
              <div class="w-12 h-12 rounded-lg bg-forest flex items-center justify-center text-white flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg text-forest mb-1">Availability</h3>
                <p class="text-slate">Monday – Friday</p>
                <p class="text-slate/70 text-sm mt-1">Flexible scheduling available</p>
              </div>
            </div>
          </div>

          <!-- Callout -->
          <div class="bg-gradient-to-br from-gold/10 to-gold/5 rounded-xl p-6 border border-gold/20">
            <div class="flex items-start gap-4">
              <div class="w-10 h-10 rounded-full bg-gold/20 flex items-center justify-center text-gold flex-shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-display text-lg text-forest mb-2">Free 30-Minute Consultation</h3>
                <p class="text-slate text-sm leading-relaxed">
                  Book a complimentary consultation to discuss your bookkeeping needs. I'll review your situation and recommend the best plan for your business.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Booking Widget -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-lg border border-forest/5 overflow-hidden">
            <div class="bg-gradient-to-br from-forest to-forest-dark p-6 text-white">
              <h2 class="font-display text-2xl mb-2">Book an Appointment</h2>
              <p class="text-white/80">Schedule your free consultation</p>
            </div>

            <div class="p-8">
              <!-- Calendly embed placeholder -->
              <div class="bg-parchment border-2 border-dashed border-forest/20 rounded-xl p-12 text-center min-h-[400px] flex flex-col items-center justify-center">
                <div class="w-20 h-20 rounded-full bg-forest/10 flex items-center justify-center text-forest mb-6">
                  <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <h3 class="font-display text-xl text-forest mb-3">Online Scheduling Coming Soon</h3>
                <p class="text-slate mb-6 max-w-sm">
                  The online booking calendar will appear here once connected.
                </p>
                <p class="text-slate/60 text-sm max-w-md">
                  To enable online booking, set up a <a href="https://calendly.com" target="_blank" rel="noopener" class="text-forest underline hover:text-gold transition-colors">Calendly</a> account and add your embed code to this page.
                </p>
              </div>

              <!--
              To add Calendly, replace the placeholder above with:

              <div class="calendly-inline-widget" data-url="https://calendly.com/YOUR-USERNAME/30min" style="min-width:320px;height:630px;"></div>
              <script type="text/javascript" src="https://assets.calendly.com/assets/external/widget.js" async></script>
              -->

              <!-- Alternative contact -->
              <div class="mt-8 pt-8 border-t border-forest/10 text-center">
                <p class="text-slate mb-4">Or reach out directly via email:</p>
                <a href="mailto:hello@backcountrybeancounter.com" class="btn-primary inline-flex items-center gap-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                  <span>Send Email</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Map/Location section (optional visual) -->
  <section class="py-16 bg-parchment">
    <div class="max-w-6xl mx-auto px-6 lg:px-8">
      <div class="bg-forest rounded-2xl p-8 md:p-12 relative overflow-hidden">
        <div class="absolute inset-0 topo-pattern opacity-20"></div>

        <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-8">
          <div>
            <h3 class="font-display text-2xl md:text-3xl text-white mb-3">
              Proudly Serving Vermont
            </h3>
            <p class="text-white/80 max-w-lg">
              Based in Central Vermont with remote services available throughout the Green Mountain State.
              Let's keep your business running as smoothly as Vermont's rolling hills.
            </p>
          </div>
          <div class="flex items-center gap-6 text-white/80">
            <svg class="w-16 h-16 text-gold/30" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <div>
              <p class="font-display text-xl text-white">Central Vermont</p>
              <p class="text-gold text-sm">Remote services statewide</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
